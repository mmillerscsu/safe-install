  },
  "dependencies": {
    "chalk": "5.3.0",
    "commander": "12.0.0",
    "node-fetch": "3.3.2"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "type": "module"
}
