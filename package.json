{
  "name": "safe-install",
  "version": "0.1.0",
  "description": "A safer way to npm install ✅",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmillerscsu/safe-install"
  },
  "bugs": {
    "url": "https://github.com/mmillerscsu/safe-install/issues"
  },
  "engines": {
